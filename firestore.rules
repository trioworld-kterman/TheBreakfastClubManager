rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /groups/{groupId} {
      allow get: if true;
      allow list: if false;
      allow create: if request.resource.data.keys().hasAll(['key', 'name', 'employees'])
                    && request.resource.data.keys().hasOnly(['key', 'name', 'employees', 'createdAt', 'updatedAt', 'lastRotatedAt'])
                    && request.resource.data.key == groupId
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.employees is list
                    && request.resource.data.employees.size() <= 50;
      allow update: if request.resource.data.keys().hasAll(['key', 'name', 'employees'])
                    && request.resource.data.keys().hasOnly(['key', 'name', 'employees', 'createdAt', 'updatedAt', 'lastRotatedAt'])
                    && request.resource.data.key == resource.data.key
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.employees is list
                    && request.resource.data.employees.size() <= 50;
      allow delete: if false;
    }

    match /ideas/{ideaId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['title', 'description', 'votesUp', 'votesDown', 'status', 'createdAt'])
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.votesUp == 0
                    && request.resource.data.votesDown == 0
                    && request.resource.data.status == 'open';
      allow update: if request.resource.data.keys().hasOnly(['title', 'description', 'votesUp', 'votesDown', 'status', 'createdAt'])
                    && request.resource.data.keys().hasAll(['title', 'votesUp', 'votesDown', 'status'])
                    && request.resource.data.title is string
                    && request.resource.data.votesUp is int
                    && request.resource.data.votesDown is int;
      allow delete: if true;
    }

    match /votes/{voteId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
